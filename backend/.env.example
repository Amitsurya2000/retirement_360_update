# Copy to backend/.env and fill in. docker-compose provides DATABASE_URL automatically.

# Postgres. For local-without-docker, point at your own instance.
DATABASE_URL=postgresql+psycopg://retire:retire@localhost:5432/retire360

# Google Gemini (free tier, no card): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# CORS — the frontend origins allowed to call this API.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

DEBUG=false
