# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — never commit your real keys.

# ─────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────
# On Vercel: create a Postgres database in the Vercel dashboard
# (Storage → Create Database → Postgres). Vercel auto-injects DATABASE_URL.
#
# For local dev: use the SAME hosted Postgres URL (simplest), or run a
# local Postgres. Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/retirewell?sslmode=require"

# ─────────────────────────────────────────────────────────────────────
# GEMINI (free tier, no credit card)
# ─────────────────────────────────────────────────────────────────────
# 1. Go to https://aistudio.google.com/apikey
# 2. Sign in with Google → "Create API key"
# 3. Copy the key (starts with AIza...) and paste below
GEMINI_API_KEY="AIza..."

# ─────────────────────────────────────────────────────────────────────
# SUPABASE AUTH (sign-up: Google / phone)
# ─────────────────────────────────────────────────────────────────────
# Find these in your Supabase project: Settings → API.
#   - Project URL  → NEXT_PUBLIC_SUPABASE_URL
#   - anon public key → NEXT_PUBLIC_SUPABASE_ANON_KEY
# Until BOTH are set, the app runs without login (no gating).
#
# To enable "Continue with Google": Supabase Dashboard → Authentication →
#   Providers → Google → enable + paste your Google OAuth client ID/secret,
#   and add  <your-domain>/auth/callback  as an authorized redirect URL.
# To enable phone sign-in: Authentication → Providers → Phone → enable and
#   connect an SMS provider (e.g. Twilio).
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
