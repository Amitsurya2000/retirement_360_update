# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — never commit your real keys.

# ─────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────
# On Vercel: create a Postgres database in the Vercel dashboard
# (Storage → Create Database → Postgres). Vercel auto-injects DATABASE_URL.
#
# For local dev: use the SAME hosted Postgres URL (simplest), or run a
# local Postgres. Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/retirewell?sslmode=require"

# ─────────────────────────────────────────────────────────────────────
# GEMINI (free tier, no credit card)
# ─────────────────────────────────────────────────────────────────────
# 1. Go to https://aistudio.google.com/apikey
# 2. Sign in with Google → "Create API key"
# 3. Copy the key (starts with AIza...) and paste below
GEMINI_API_KEY="AIza..."
